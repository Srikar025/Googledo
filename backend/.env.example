# ─────────────────────────────────────────────────────────────
# CollabDocs — Backend Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL (Supabase) ──────────────────────────────────────
# Get these from: Supabase Dashboard → Project → Settings → Database → Connection string
# Use the "Pooler" connection for DATABASE_URL (port 6543, transaction mode)
# Use the "Direct" connection for DIRECT_URL (port 5432, for migrations)

DATABASE_URL="postgresql://postgres.<project-ref>:<your-password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<your-password>@aws-<region>.pooler.supabase.com:5432/postgres"

# ── Redis (Upstash) ───────────────────────────────────────────
# Get this from: Upstash Console → your database → Connect → Redis URL
# The URL starts with "rediss://" (TLS enabled)

REDIS_URL="rediss://default:<your-password>@<your-host>.upstash.io:6379"

# ── CORS / Frontend Origin ────────────────────────────────────
# Set this to the URL where your frontend is running.
# In development: http://localhost:3000
# In production: https://your-deployed-frontend.vercel.app

FRONTEND_URL="http://localhost:3000"

# ── Server Port (optional) ────────────────────────────────────
# Defaults to 5000 if not set.
# PORT=5000
