# ─────────────────────────────────────────────────────────────
# CollabDocs — Frontend Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────
# In development: leave empty (Vite proxy handles /api → localhost:5000)
# In production (Vercel): set to your Render backend URL
# VITE_BACKEND_URL=https://your-backend.onrender.com
